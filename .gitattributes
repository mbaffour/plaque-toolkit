# Keep Unix line endings on scripts that must run on macOS/Linux.
# Without this, core.autocrlf=true on Windows would store CRLF and break the
# shebang / bash parsing on the target OS.
*.sh        text eol=lf
*.command   text eol=lf
build_macos.sh text eol=lf

# Windows batch files want CRLF.
*.bat       text eol=crlf

# Don't munge binary assets.
*.png       binary
*.ico       binary
*.icns      binary

# Large binaries (test images + model weights) should go through Git LFS from
# now on so the repo stays small. This only affects files added/changed after
# LFS is enabled (`git lfs install`) -- history is intentionally not rewritten,
# so blobs already committed stay where they are. New large assets are better
# published as GitHub release assets; see the "Large files" note in README.md.
*.tif       filter=lfs diff=lfs merge=lfs -text
*.tiff      filter=lfs diff=lfs merge=lfs -text
*.heic      filter=lfs diff=lfs merge=lfs -text
*.pt        filter=lfs diff=lfs merge=lfs -text
